APP_ENV=dev
APP_BIND_ADDR=0.0.0.0:8080
SERVICE_NAME=aegis-broker-backend-dev
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aegisbroker_dev
MAX_DB_CONNECTIONS=5
RUST_LOG=debug
SESSION_TTL_HOURS=24
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
GOOGLE_CONNECTOR_REDIRECT_URI=http://localhost:3000/oauth/google/connector/callback
GOOGLE_OAUTH_SCOPE=openid email profile
