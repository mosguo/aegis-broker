# AegisBroker default environment profile (shared baseline)
# Secrets should be injected by Zeabur Environment Variables.
# Do not place real secret values in version control.

# Runtime
APP_ENV=dev
APP_BIND_ADDR=0.0.0.0:8080
SERVICE_NAME=aegis-broker-backend
RUST_LOG=info

# Database
DATABASE_URL=
MAX_DB_CONNECTIONS=5

# Auth / Session
SESSION_TTL_HOURS=24
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_CONNECTOR_REDIRECT_URI=
GOOGLE_OAUTH_SCOPE=openid email profile

# Frontend
BACKEND_API_BASE_URL=http://localhost:8080
DEFAULT_LOCALE=zh-TW
ENABLED_LOCALES=zh-TW,zh-CN,en,es,tr

# Payment (reserved, keep empty until provisioned)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Infrastructure
POSTGRES_PASSWORD=
